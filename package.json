{
  "name": "fm-wrap",
  "version": "0.1.3",
  "description": "Wraps Apple's macOS fm CLI as a library and RESTful web service",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "bun dist/server/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build && bun run test && bun run typecheck",
    "release": "bash scripts/release.sh"
  },
  "keywords": [
    "apple",
    "foundation-models",
    "fm",
    "pcc",
    "openai-compatible",
    "macos"
  ],
  "author": "Tariq West",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tariqwest/fm-wrap.git"
  },
  "homepage": "https://github.com/tariqwest/fm-wrap#readme",
  "bugs": {
    "url": "https://github.com/tariqwest/fm-wrap/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "os": [
    "darwin"
  ],
  "dependencies": {
    "hono": "^4.12.27",
    "node-pty": "^1.1.0",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@hono/node-server": "^2.0.6",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.1",
    "@types/uuid": "^11.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
